# =============================================================================
# iNBIO Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Blog Post Generator (pick ONE provider) ---
# Set AI_PROVIDER to choose: anthropic, gemini, openai, groq, deepseek, mistral, ollama
# If not set, auto-detects from available API keys (cheapest first)
AI_PROVIDER=gemini

# Google Gemini (FREE tier — recommended to start)
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Groq (FREE tier — very fast)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-key-here

# Mistral (FREE tier)
# Get key at: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-mistral-key-here

# Anthropic Claude (best quality, ~$0.02/post)
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (~$0.001/post)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# DeepSeek (~$0.001/post)
# Get key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-key-here

# Ollama (FREE — runs locally, no key needed)
# Install: https://ollama.ai, then run: ollama pull llama3.2

# --- Email Notifications (form submissions) ---
# Resend — free tier: 100 emails/month
# Get key at: https://resend.com/api-keys
RESEND_API_KEY=re_your-key-here
CONTACT_EMAIL=Raj@inbio.net

# --- Google Sheets Logging (form submissions) ---
GOOGLE_SHEETS_ID=your-sheet-id-here
GOOGLE_SHEETS_API_KEY=your-api-key-here

# --- WhatsApp ---
WHATSAPP_NUMBER=14105551234
